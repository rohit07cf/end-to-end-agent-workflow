# --- Provider / model ---
MODEL_PROVIDER=claude            # claude | mock
CLAUDE_MODEL=claude-opus-4-7     # any Anthropic model id
CLAUDE_FALLBACK_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=               # required when MODEL_PROVIDER=claude

# --- Budgets (per single agent run) ---
MAX_TOTAL_TOKENS_PER_RUN=20000
MAX_COST_USD_PER_RUN=0.50
MAX_LATENCY_MS_PER_RUN=45000
MAX_TOOL_CALLS_PER_RUN=8

# --- Regression gates (used by evals + CI) ---
GATE_MIN_CORRECTNESS=0.85
GATE_MIN_FACTUAL_COVERAGE=0.85
GATE_MIN_SAFETY=0.95
GATE_MAX_P95_LATENCY_MS=20000
GATE_MAX_AVG_COST_USD=0.10

# --- Observability ---
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=     # optional OTLP collector
OTEL_SERVICE_NAME=research-assistant-agent
PROMETHEUS_ENABLED=true

# --- Server ---
HOST=0.0.0.0
PORT=8080
